pm() {
  local package_directory="$PWD"

  while [ "$package_directory" != "/" ]; do
    if [ -f "$package_directory/pnpm-lock.yaml" ] ||
      { [ -f "$package_directory/package.json" ] && grep -q '"packageManager"[[:space:]]*:[[:space:]]*"pnpm@' "$package_directory/package.json"; }; then
      command pnpm "$@"
      return
    fi

    if [ -f "$package_directory/package-lock.json" ] ||
      { [ -f "$package_directory/package.json" ] && grep -q '"packageManager"[[:space:]]*:[[:space:]]*"npm@' "$package_directory/package.json"; }; then
      command npm "$@"
      return
    fi

    package_directory=${package_directory%/*}
    [ -n "$package_directory" ] || package_directory="/"
  done

  command npm "$@"
}

